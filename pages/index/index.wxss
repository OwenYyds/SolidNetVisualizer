.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 205, 122, 0.22), transparent 38%),
    radial-gradient(circle at top right, rgba(122, 211, 164, 0.14), transparent 34%),
    linear-gradient(180deg, #f9f7f1 0%, #f3f2ea 100%);
}

.hero {
  margin-bottom: 28rpx;
}

.eyebrow {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #6d7282;
  text-transform: uppercase;
}

.title {
  margin-top: 12rpx;
  font-size: 52rpx;
  font-weight: 800;
  color: #151c2d;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #55606f;
}

.shape-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.shape-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(37, 48, 67, 0.08);
  box-shadow: 0 14rpx 32rpx rgba(24, 32, 48, 0.06);
}

.shape-card.active {
  border-color: rgba(37, 48, 67, 0.2);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 242, 232, 0.94));
}

.shape-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2430;
}

.shape-card__subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #627084;
}

.panel {
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(37, 48, 67, 0.08);
  box-shadow: 0 18rpx 48rpx rgba(24, 32, 48, 0.08);
}

.panel__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.panel__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #182030;
}

.panel__subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #607085;
}

.panel__badge {
  flex: none;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #35506a;
  background: rgba(53, 80, 106, 0.1);
}

.mode-tabs {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.mode-tab {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #516070;
  background: rgba(241, 244, 248, 0.95);
}

.mode-tab.selected {
  color: #ffffff;
  background: linear-gradient(135deg, #24324a 0%, #435673 100%);
}

.tips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.tip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(241, 244, 248, 0.95);
  color: #607085;
  font-size: 22rpx;
}
